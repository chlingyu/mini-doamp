{
  "title": "Mini DOAMP - Application Overview",
  "uid": "mini-doamp-overview",
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "refresh": "15s",
  "tags": ["mini-doamp", "java", "spring-boot"],
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "JVM Uptime (s)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "process_uptime_seconds{application=\"mini-doamp\"}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Heap Used (MB)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{area=\"heap\",application=\"mini-doamp\"}) / 1024 / 1024", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "CPU %",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "process_cpu_usage{application=\"mini-doamp\"} * 100", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100 } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active HTTP Requests",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "sum(http_server_requests_active_seconds_count{application=\"mini-doamp\"})", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Requests QPS (by status)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{application=\"mini-doamp\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP Latency P50 / P95 / P99 (seconds)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5,  sum by (le) (rate(http_server_requests_seconds_bucket{application=\"mini-doamp\"}[5m])))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"mini-doamp\"}[5m])))",
          "refId": "B",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"mini-doamp\"}[5m])))",
          "refId": "C",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Warn Rules Triggered (by indexType)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (indexType) (increase(warn_triggered_total{application=\"mini-doamp\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{indexType}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Notification Publish Outcome",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (channel, outcome) (rate(notify_publish_total{application=\"mini-doamp\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{channel}}-{{outcome}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "SOP Task Advance (action x outcome)",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (action, outcome) (rate(sop_task_advance_total{application=\"mini-doamp\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{action}}-{{outcome}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "JVM Heap Used vs Max (bytes)",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\",application=\"mini-doamp\"})",
          "refId": "A",
          "legendFormat": "used"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{area=\"heap\",application=\"mini-doamp\"})",
          "refId": "B",
          "legendFormat": "max"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ]
}
