# ╔══════════════════════════════════════════════════════════╗
# ║  Mini-DOAMP 环境变量参考清单                             ║
# ║                                                        ║
# ║  本文件仅作文档参考，Spring Boot 不会自动加载 .env 文件。  ║
# ║  请通过以下方式注入环境变量：                              ║
# ║    · IDE Run Configuration → Environment Variables      ║
# ║    · 启动命令: DB_PASSWORD=xxx java -jar app.jar        ║
# ║    · Docker: docker run -e DB_PASSWORD=xxx ...          ║
# ║    · docker-compose.yml 的 environment 字段             ║
# ╚══════════════════════════════════════════════════════════╝

# ── 数据库 ──
DB_URL=jdbc:mysql://localhost:3306/mini_doamp?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_db_password

# ── RabbitMQ ──
RABBIT_HOST=localhost
RABBIT_PORT=5672
RABBIT_USERNAME=guest
RABBIT_PASSWORD=your_rabbit_password

# ── JWT（必须配置，无默认值） ──
# 密钥至少 32 字符，生产环境必须自行生成
JWT_SECRET=your_jwt_secret_at_least_32_chars
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ── XXL-Job ──
XXL_JOB_ACCESS_TOKEN=your_xxl_job_token
